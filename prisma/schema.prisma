generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  owner
  admin
  manager
  creator
}

enum ContentType {
  image
  video
  file
  bundle
}

enum PurchaseStatus {
  pending
  paid
  expired
  refunded
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum DocStatus {
  none
  pending
  approved
  rejected
}

enum LiveQualityTier {
  SD
  HD
}

enum LiveSessionStatus {
  live
  ended
  failed
}

enum ContentDeliveryMode {
  ondemand
  catalog
}

enum ProvisionJobStatus {
  pending
  processing
  success
  pending_manual
  failed
}

// Tipo de chave Pix conforme aceito pela Woovi/OpenPix.
// Usado em User.pixKeyType para validar o formato de User.pixKey.
enum PixKeyType {
  cpf
  cnpj
  email
  phone
  random
}

// Estado do provisionamento da subconta Woovi vinculada à chave Pix do usuário.
// - none: ainda sem pixKey ou sem tentativa de provisionamento.
// - pending: job enfileirado ou em execução.
// - active: subconta criada na Woovi e pronta para receber splits.
// - failed: última tentativa falhou — detalhes em wooviSubAccountError.
enum WooviSubAccountStatus {
  none
  pending
  active
  failed
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique @db.VarChar(255)
  passwordHash       String    @map("password_hash") @db.VarChar(255)
  name               String    @db.VarChar(255)
  role               UserRole  @default(creator)
  avatarUrl          String?   @map("avatar_url") @db.VarChar(500)
  avatarKey          String?   @map("avatar_key") @db.VarChar(500)
  docType            String?   @map("doc_type") @db.VarChar(10)
  docFrontKey        String?   @map("doc_front_key") @db.VarChar(500)
  docBackKey         String?   @map("doc_back_key") @db.VarChar(500)
  docSelfieKey       String?   @map("doc_selfie_key") @db.VarChar(500)
  docStatus          DocStatus @default(none) @map("doc_status")
  docRejectReason    String?   @map("doc_reject_reason") @db.Text
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  // Pro role=creator: taxa da plataforma cobrada nele (quando standalone) ou ignorado (quando managed — usa manager.platformFeePercent).
  // Pro role=manager: taxa da plataforma cobrada em cada transação dos creators que ele gere.
  platformFeePercent Decimal   @default(10.00) @map("platform_fee_percent") @db.Decimal(5, 2)
  // Quando role=creator + managedBy preenchido: taxa do manager sobre o bruto do creator. Caso contrário, ignorado.
  managerFeePercent  Decimal?  @map("manager_fee_percent") @db.Decimal(5, 2)
  // Self-ref: creator → manager que o gere. null = standalone.
  managedByUserId    String?   @map("managed_by_user_id") @db.Uuid
  // Dados de pagamento (preenchidos apenas por creator/manager).
  // CPF armazenado em dígitos puros (sem pontuação).
  cpf                String?   @unique @db.VarChar(11)
  // Telefone em E.164 (ex.: +5511999998888).
  phone              String?   @db.VarChar(20)
  // Chave Pix usada como destino de repasse via Split Pix (Woovi).
  // É @unique porque a Woovi usa a própria chave como identificador da subconta.
  pixKey             String?   @unique @map("pix_key") @db.VarChar(255)
  pixKeyType         PixKeyType? @map("pix_key_type")
  // Estado do provisionamento da subconta Woovi atrelada à pixKey acima.
  wooviSubAccountStatus WooviSubAccountStatus @default(none) @map("woovi_subaccount_status")
  wooviSubAccountError  String?   @map("woovi_subaccount_error") @db.Text
  wooviSubAccountProvisionedAt DateTime? @map("woovi_subaccount_provisioned_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at")

  bots                 Bot[]
  content              Content[]
  purchases            Purchase[]
  updatedSettings      PlatformSetting[]
  qaReports            QaReport[]
  solicitations        Solicitation[]
  solicitationComments SolicitationComment[]
  liveSchedules        LiveSchedule[]
  managedBy            User?     @relation("UserManager", fields: [managedByUserId], references: [id], onDelete: SetNull)
  managedCreators      User[]    @relation("UserManager")
  purchaseManagerFees  Purchase[]     @relation("PurchaseManager")
  subscriptionManagerFees Subscription[] @relation("SubscriptionManager")

  @@index([managedByUserId])
  @@map("users")
}

model Bot {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  name             String    @db.VarChar(255)
  username         String?   @unique @db.VarChar(255)
  telegramToken    String    @map("telegram_token") @db.VarChar(500)
  description      String?   @db.Text
  isActive         Boolean   @default(false) @map("is_active")
  webhookUrl       String?   @map("webhook_url") @db.VarChar(500)
  totalSubscribers Int       @default(0) @map("total_subscribers")
  totalRevenue     Decimal   @default(0.00) @map("total_revenue") @db.Decimal(12, 2)
  // Canal Telegram vinculado ao bot. Quando setado, conteúdo catalog é
  // postado no canal e assinantes recebem invite link member_limit=1 ao pagar.
  channelId        BigInt?   @map("channel_id")
  channelUsername  String?   @map("channel_username") @db.VarChar(255)
  channelTitle     String?   @map("channel_title") @db.VarChar(255)
  channelLinkedAt  DateTime? @map("channel_linked_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  content           Content[]
  botUsers          BotUser[]
  purchases         Purchase[]
  welcomeMessage    WelcomeMessage?
  subscriptionPlans SubscriptionPlan[]
  subscriptions     Subscription[]
  liveStream        LiveStream?
  liveSchedules     LiveSchedule[]

  @@map("bots")
}

model Content {
  id            String              @id @default(uuid()) @db.Uuid
  botId         String              @map("bot_id") @db.Uuid
  userId        String              @map("user_id") @db.Uuid
  title         String              @db.VarChar(255)
  description   String?             @db.Text
  type          ContentType
  price         Decimal             @db.Decimal(10, 2)
  originalKey   String              @map("original_key") @db.VarChar(500)
  previewKey    String?             @map("preview_key") @db.VarChar(500)
  thumbnailKey  String?             @map("thumbnail_key") @db.VarChar(500)
  originalUrl   String?             @map("original_url") @db.VarChar(1000)
  previewUrl    String?             @map("preview_url") @db.VarChar(1000)
  isPublished   Boolean             @default(false) @map("is_published")
  // ondemand = compra avulsa via Pix; catalog = entregue automaticamente
  // aos assinantes ativos quando a hora chega (publishedAt). Catalog ignora
  // price — é parte do benefício da assinatura.
  deliveryMode  ContentDeliveryMode @default(ondemand) @map("delivery_mode")
  // Se definido e no futuro, worker content-schedule-enforcer publica/entrega
  // quando a hora chega. Se null, publicação é imediata (via createContent).
  scheduledAt   DateTime?           @map("scheduled_at")
  // Marcado quando worker efetivamente publicou/entregou. Dupla função:
  // (1) evita publicação duplicada; (2) serve de histórico.
  publishedAt   DateTime?           @map("published_at")
  purchaseCount Int                 @default(0) @map("purchase_count")
  totalRevenue  Decimal             @default(0.00) @map("total_revenue") @db.Decimal(12, 2)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @default(now()) @updatedAt @map("updated_at")

  bot       Bot        @relation(fields: [botId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@index([botId, scheduledAt])
  @@index([scheduledAt, publishedAt])
  @@map("content")
}

model BotUser {
  id                String   @id @default(uuid()) @db.Uuid
  botId             String   @map("bot_id") @db.Uuid
  telegramUserId    BigInt   @map("telegram_user_id")
  telegramUsername  String?  @map("telegram_username") @db.VarChar(255)
  telegramFirstName String?  @map("telegram_first_name") @db.VarChar(255)
  firstSeenAt       DateTime @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime @default(now()) @map("last_seen_at")

  bot           Bot            @relation(fields: [botId], references: [id], onDelete: Cascade)
  purchases     Purchase[]
  subscriptions Subscription[]

  @@unique([botId, telegramUserId])
  @@map("bot_users")
}

model Purchase {
  id             String         @id @default(uuid()) @db.Uuid
  contentId      String?        @map("content_id") @db.Uuid
  botId          String         @map("bot_id") @db.Uuid
  botUserId      String         @map("bot_user_id") @db.Uuid
  creatorUserId  String         @map("creator_user_id") @db.Uuid
  // Quando creator é gerenciado, managerUserId armazena quem recebeu managerFee.
  managerUserId  String?        @map("manager_user_id") @db.Uuid
  amount         Decimal        @db.Decimal(10, 2)
  platformFee    Decimal        @map("platform_fee") @db.Decimal(10, 2)
  managerFee     Decimal        @default(0.00) @map("manager_fee") @db.Decimal(10, 2)
  creatorNet     Decimal        @map("creator_net") @db.Decimal(10, 2)
  pixTxid        String?        @unique @map("pix_txid") @db.VarChar(255)
  pixQrCode      String?        @map("pix_qr_code") @db.Text
  pixCopyPaste   String?        @map("pix_copy_paste") @db.Text
  // Quando true, o charge foi criado na Woovi já com splits apontados para
  // as subcontas do creator/manager. Usado pra auditoria e pra decidir se
  // vale acionar saque automático sobre essa transação.
  splitApplied   Boolean        @default(false) @map("split_applied")
  status         PurchaseStatus @default(pending)
  paidAt         DateTime?      @map("paid_at")
  expiresAt      DateTime?      @map("expires_at")
  createdAt      DateTime       @default(now()) @map("created_at")

  content     Content? @relation(fields: [contentId], references: [id], onDelete: Cascade)
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  botUser     BotUser  @relation(fields: [botUserId], references: [id], onDelete: Cascade)
  creatorUser User     @relation(fields: [creatorUserId], references: [id], onDelete: Cascade)
  managerUser User?    @relation("PurchaseManager", fields: [managerUserId], references: [id], onDelete: SetNull)

  @@index([managerUserId])
  @@map("purchases")
}

model PlatformSetting {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(255)
  value       String   @db.Text
  description String?  @db.Text
  isEncrypted Boolean  @default(false) @map("is_encrypted")
  updatedBy   String?  @map("updated_by") @db.Uuid
  updatedAt   DateTime @default(now()) @map("updated_at")

  updatedByUser User? @relation(fields: [updatedBy], references: [id])

  @@map("platform_settings")
}

model WelcomeMessage {
  id               String   @id @default(uuid()) @db.Uuid
  botId            String   @unique @map("bot_id") @db.Uuid
  text             String   @db.Text
  mediaType        String?  @map("media_type") @db.VarChar(10)
  mediaKey         String?  @map("media_key") @db.VarChar(500)
  mediaUrl         String?  @map("media_url") @db.VarChar(1000)
  buttons          Json     @default("[]")
  sendOnEveryStart Boolean  @default(true) @map("send_on_every_start")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("welcome_messages")
}

model SubscriptionPlan {
  id                 String   @id @default(uuid()) @db.Uuid
  botId              String   @map("bot_id") @db.Uuid
  name               String   @db.VarChar(100)
  description        String?  @db.Text
  price              Decimal  @db.Decimal(10, 2)
  // Duração do plano em dias. Substitui o antigo enum SubscriptionPeriod
  // (monthly/quarterly/semiannual/annual → 30/90/180/365) — permite qualquer
  // duração (ex.: 7, 15, 45) sem nova migração.
  durationDays       Int      @map("duration_days")
  benefits           Json     @default("[]")
  isActive           Boolean  @default(true) @map("is_active")
  sortOrder          Int      @default(0) @map("sort_order")
  includesLiveAccess Boolean  @default(false) @map("includes_live_access")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  bot           Bot            @relation(fields: [botId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                    String             @id @default(uuid()) @db.Uuid
  planId                String             @map("plan_id") @db.Uuid
  botId                 String             @map("bot_id") @db.Uuid
  botUserId             String             @map("bot_user_id") @db.Uuid
  // Quando creator é gerenciado, managerUserId armazena quem recebeu managerFee.
  managerUserId         String?            @map("manager_user_id") @db.Uuid
  status                SubscriptionStatus @default(active)
  amount                Decimal            @db.Decimal(10, 2)
  platformFee           Decimal            @map("platform_fee") @db.Decimal(10, 2)
  managerFee            Decimal            @default(0.00) @map("manager_fee") @db.Decimal(10, 2)
  creatorNet            Decimal            @map("creator_net") @db.Decimal(10, 2)
  pixTxid               String?            @unique @map("pix_txid") @db.VarChar(255)
  pixQrCode             String?            @map("pix_qr_code") @db.Text
  pixCopyPaste          String?            @map("pix_copy_paste") @db.Text
  // Ver Purchase.splitApplied.
  splitApplied          Boolean            @default(false) @map("split_applied")
  startDate             DateTime?          @map("start_date")
  endDate               DateTime?          @map("end_date")
  paidAt                DateTime?          @map("paid_at")
  // Canal: invite link criado ao pagamento (member_limit=1),
  // timestamps de entrada/saída + motivo de remoção pra auditoria.
  channelInviteLink     String?            @map("channel_invite_link") @db.VarChar(500)
  channelInviteSentAt   DateTime?          @map("channel_invite_sent_at")
  channelJoinedAt       DateTime?          @map("channel_joined_at")
  channelRemovedAt      DateTime?          @map("channel_removed_at")
  channelRemovalReason  String?            @map("channel_removal_reason") @db.VarChar(50)
  createdAt             DateTime           @default(now()) @map("created_at")

  plan        SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  bot         Bot              @relation(fields: [botId], references: [id], onDelete: Cascade)
  botUser     BotUser          @relation(fields: [botUserId], references: [id], onDelete: Cascade)
  managerUser User?            @relation("SubscriptionManager", fields: [managerUserId], references: [id], onDelete: SetNull)

  @@index([managerUserId])
  @@map("subscriptions")
}

model LiveStream {
  id                String   @id @default(uuid()) @db.Uuid
  botId             String   @unique @map("bot_id") @db.Uuid
  isLive            Boolean  @default(false) @map("is_live")
  title             String?  @db.VarChar(255)
  description       String?  @db.Text
  price             Decimal  @default(0.00) @db.Decimal(10, 2)
  streamLink        String?  @map("stream_link") @db.VarChar(1000)
  notifySubscribers Boolean  @default(false) @map("notify_subscribers")
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at")

  // ─── IVS (Amazon Interactive Video Service) ───
  // Um canal IVS por bot, reusado entre lives. Criado on-demand em upsertLiveStream.
  ivsChannelArn         String?         @map("ivs_channel_arn") @db.VarChar(500)
  ivsChannelName        String?         @map("ivs_channel_name") @db.VarChar(255)
  ivsIngestEndpoint     String?         @map("ivs_ingest_endpoint") @db.VarChar(500)
  ivsPlaybackUrl        String?         @map("ivs_playback_url") @db.VarChar(1000)
  ivsStreamKeyArn       String?         @map("ivs_stream_key_arn") @db.VarChar(500)
  ivsStreamKeyEncrypted String?         @map("ivs_stream_key_encrypted") @db.Text
  ivsQualityTier        LiveQualityTier @default(HD) @map("ivs_quality_tier")

  bot      Bot                 @relation(fields: [botId], references: [id], onDelete: Cascade)
  sessions LiveStreamSession[]

  @@map("live_streams")
}

// Uma linha por sessão de live real (distinta da config em LiveStream).
// Alimentada por eventos EventBridge do IVS.
model LiveStreamSession {
  id                    String            @id @default(uuid()) @db.Uuid
  liveStreamId          String            @map("live_stream_id") @db.Uuid
  botId                 String            @map("bot_id") @db.Uuid
  ivsChannelArn         String            @map("ivs_channel_arn") @db.VarChar(500)
  ivsStreamId           String            @unique @map("ivs_stream_id") @db.VarChar(255)
  startedAt             DateTime          @map("started_at")
  endedAt               DateTime?         @map("ended_at")
  durationSeconds       Int?              @map("duration_seconds")
  peakConcurrentViewers Int?              @map("peak_concurrent_viewers")
  totalDeliveredMinutes Decimal?          @map("total_delivered_minutes") @db.Decimal(14, 4)
  qualityTier           LiveQualityTier   @default(HD) @map("quality_tier")
  inputCostUsd          Decimal?          @map("input_cost_usd") @db.Decimal(12, 6)
  outputCostUsd         Decimal?          @map("output_cost_usd") @db.Decimal(12, 6)
  totalCostUsd          Decimal?          @map("total_cost_usd") @db.Decimal(12, 6)
  status                LiveSessionStatus @default(live)
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @default(now()) @updatedAt @map("updated_at")

  liveStream LiveStream @relation(fields: [liveStreamId], references: [id], onDelete: Cascade)

  @@index([botId, startedAt])
  @@index([status])
  @@map("live_stream_sessions")
}

// ─── Agendamento de Lives (concorrência máx. 3 paralelas) ───

enum LiveScheduleStatus {
  scheduled
  started
  ended
  cancelled
  missed
}

// Uma LiveSchedule representa um horário reservado para transmissão.
// Toda live exige schedule (inclusive ad-hoc: cria schedule com startAt
// = now + 10min). Concorrência é enforced em 2 momentos:
//   1. createLiveSchedule: conta sobreposições com status IN (scheduled,
//      started). Rejeita se count >= 3.
//   2. beginBrowserBroadcast: conta status=started ativas. Rejeita se >= 3.
// Worker live-schedule-enforcer roda a cada 2min:
//   - marca missed schedules com startAt + 15min no passado
//   - força ended (+ stop no MediaMTX e IVS) quando endAt passa
model LiveSchedule {
  id                String             @id @default(uuid()) @db.Uuid
  botId             String             @map("bot_id") @db.Uuid
  title             String             @db.VarChar(255)
  description       String?            @db.Text
  price             Decimal            @default(0.00) @db.Decimal(10, 2)
  notifySubscribers Boolean            @default(false) @map("notify_subscribers")
  startAt           DateTime           @map("start_at")
  endAt             DateTime           @map("end_at")
  status            LiveScheduleStatus @default(scheduled)
  actualStartAt     DateTime?          @map("actual_start_at")
  actualEndAt       DateTime?          @map("actual_end_at")
  // Caminho efêmero criado no MediaMTX quando broadcast inicia.
  // Formato: live/{botId}/{uuid}. Usado para teardown em endBrowserBroadcast
  // e pelo worker enforcer quando precisa forçar stop.
  mediamtxPath      String?            @map("mediamtx_path") @db.VarChar(255)
  createdById       String             @map("created_by_id") @db.Uuid
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @default(now()) @updatedAt @map("updated_at")

  bot       Bot  @relation(fields: [botId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([startAt, endAt])
  @@index([botId, startAt])
  @@index([status])
  @@map("live_schedules")
}

// ─── Controle de Qualidade (QA) ───

enum QaReportStatus {
  EM_ANDAMENTO
  FINALIZADO
}

model QaTask {
  id        String   @id @default(uuid()) @db.Uuid
  nome      String   @db.VarChar(255)
  descricao String?  @db.Text
  ativo     Boolean  @default(true)
  ordem     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  reportItems QaReportItem[]

  @@map("qa_tasks")
}

model QaReport {
  id           String         @id @default(uuid()) @db.Uuid
  titulo       String         @db.VarChar(255)
  publicToken  String         @unique @default(uuid()) @map("public_token") @db.Uuid
  status       QaReportStatus @default(EM_ANDAMENTO)
  criadoPorId  String         @map("criado_por_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  finalizadoEm DateTime?      @map("finalizado_em")

  criadoPor User           @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)
  items     QaReportItem[]

  @@map("qa_reports")
}

model QaReportItem {
  id        String   @id @default(uuid()) @db.Uuid
  reportId  String   @map("report_id") @db.Uuid
  taskId    String   @map("task_id") @db.Uuid
  marcado   Boolean  @default(false)
  anotacoes String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  report QaReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  task   QaTask   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([reportId, taskId])
  @@map("qa_report_items")
}

// ─── Solicitações ───

enum SolicitationStatus {
  SOLICITADO
  EM_ANDAMENTO
  NEGADA
  FINALIZADA
}

model Solicitation {
  id          String             @id @default(uuid()) @db.Uuid
  titulo      String             @db.VarChar(255)
  descricao   String             @db.Text
  status      SolicitationStatus @default(SOLICITADO)
  prioridade  Int                @default(0)
  criadoPorId String             @map("criado_por_id") @db.Uuid
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @default(now()) @updatedAt @map("updated_at")

  criadoPor User                  @relation(fields: [criadoPorId], references: [id], onDelete: Cascade)
  comments  SolicitationComment[]

  @@map("solicitations")
}

model SolicitationComment {
  id             String   @id @default(uuid()) @db.Uuid
  solicitationId String   @map("solicitation_id") @db.Uuid
  autorId        String   @map("autor_id") @db.Uuid
  texto          String   @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  solicitation Solicitation             @relation(fields: [solicitationId], references: [id], onDelete: Cascade)
  autor        User                     @relation(fields: [autorId], references: [id], onDelete: Cascade)
  attachments  SolicitationAttachment[]

  @@map("solicitation_comments")
}

model SolicitationAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  commentId String   @map("comment_id") @db.Uuid
  fileKey   String   @map("file_key") @db.VarChar(500)
  fileUrl   String?  @map("file_url") @db.VarChar(1000)
  fileName  String   @map("file_name") @db.VarChar(255)
  fileType  String   @map("file_type") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at")

  comment SolicitationComment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@map("solicitation_attachments")
}

model ProvisionJob {
  id                 String             @id @default(uuid()) @db.Uuid
  externalId         String             @map("external_id") @db.VarChar(255)
  email              String             @db.VarChar(255)
  displayName        String             @map("display_name") @db.VarChar(255)
  platformFeePercent Decimal?           @map("platform_fee_percent") @db.Decimal(5, 2)
  status             ProvisionJobStatus @default(pending)
  userId             String?            @map("user_id") @db.Uuid
  botId              String?            @map("bot_id") @db.Uuid
  attempts           Int                @default(0)
  lastError          String?            @map("last_error") @db.Text
  attemptedUsernames String[]           @default([]) @map("attempted_usernames")
  botUsername        String?            @map("bot_username") @db.VarChar(255)
  tempPassword       String?            @map("temp_password") @db.VarChar(255)
  tempPasswordReadAt DateTime?          @map("temp_password_read_at")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @default(now()) @updatedAt @map("updated_at")
  completedAt        DateTime?          @map("completed_at")

  @@index([externalId, createdAt])
  @@index([status, createdAt])
  @@map("provision_jobs")
}
