# App
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
ENCRYPTION_SECRET=

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/botfans

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Storage (valores padrão — podem ser sobrescritos via admin panel)
DEFAULT_STORAGE_PROVIDER=s3
DEFAULT_STORAGE_BUCKET=
DEFAULT_STORAGE_REGION=us-east-1
DEFAULT_STORAGE_ENDPOINT=
DEFAULT_STORAGE_ACCESS_KEY_ID=
DEFAULT_STORAGE_SECRET_ACCESS_KEY=

# Live Streaming (Amazon IVS)
# IVS não roda em sa-east-1 — use us-east-1 pra o SDK (IvsClient, CloudWatchClient)
IVS_REGION=us-east-1

# Chave privada ECDSA P-384 (PEM, multiline) correspondente à PlaybackKeyPair
# importada no IVS. Gerar com:
#   openssl ecparam -name secp384r1 -genkey -noout -out private.pem
#   openssl ec -in private.pem -pubout -out public.pem
# Depois importar public.pem no IVS via aws ivs import-playback-key-pair ...
IVS_PLAYBACK_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----"

# Shared secret pra autenticar o webhook EventBridge em /api/webhooks/ivs
IVS_WEBHOOK_SECRET=

# Seed (owner inicial)
SEED_OWNER_EMAIL=admin@botfans.com
SEED_OWNER_PASSWORD=
SEED_OWNER_NAME=Admin
